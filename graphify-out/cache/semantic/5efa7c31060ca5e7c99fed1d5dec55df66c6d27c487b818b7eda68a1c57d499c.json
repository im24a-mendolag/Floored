"contributor": null}, {"id": "game_template_curse_mechanic", "label": "Curse Mechanic (loseGame / useCurse)", "file_type": "rationale", "source_file": "GAME_TEMPLATE.txt", "source_location": "\u00a714 CURSE MECHANIC", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every engine exports loseGame(); every component wires useCurse(). Swap must be invisible to player \u2014 same animation/message/timing. Allows dev mode to force losses for testing."}, {"id": "game_template_bless_mechanic", "label": "Bless Mechanic (winGame / useBless)", "file_type": "rationale", "source_file": "GAME_TEMPLATE.txt", "source_location": "\u00a715 BLESS MECHANIC", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every engine exports winGame(); priority order: blessed\u2192cursed\u2192normal. Blessed overrides curse. Gives variety \u2014 not hardcoded minimum win; respects player held state."}, {"id": "game_template_color_palette", "label": "Design Color Palette", "file_type": "rationale", "source_file": "GAME_TEMPLATE.txt", "source_location": "\u00a711 COLOR PALETTE", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Standardized zinc-950/900 backgrounds, emerald for wins, red for losses, yellow for selection highlights, white CTA buttons. Consistency across all 18 game components."}, {"id": "game_template_game_states", "label": "Game Stage State Convention", "file_type": "document", "source_file": "GAME_TEMPLATE.txt", "source_location": "\u00a712 GAME STATES CONVENTION", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "game_template_file_structure", "target": "ai_handshake_engine_purity", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "GAME_TEMPLATE.txt", "source_location": "\u00a71 games/<name>/engine.ts is pure logic", "weight": 1.0}, {"source": "game_