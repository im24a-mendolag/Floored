generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String         @id @default(cuid())
  email      String         @unique
  username   String?        @unique
  createdAt  DateTime       @default(now())
  runs       Run[]
  cosmetics  UserCosmetic[]
}

model Run {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  difficulty    String
  startedAt     DateTime     @default(now())
  endedAt       DateTime?
  endBankroll   Int?
  peakBankroll  Int          @default(1000)
  floorsReached Int          @default(0)
  gamesPlayed   Int          @default(0)
  seed          String
  diceWinSums   Int[]
  diceLossSums  Int[]
  results       GameResult[]
}

model GameResult {
  id         String   @id @default(cuid())
  runId      String
  run        Run      @relation(fields: [runId], references: [id])
  game       String
  floor      Int
  betAmount  Int
  payout     Int
  outcome    String
  multiplier Float?
  playedAt   DateTime @default(now())
}

model UserCosmetic {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  type       String
  itemId     String
  unlockedAt DateTime @default(now())
}
