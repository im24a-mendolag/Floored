{"nodes": [{"id": "ai_handshake_floored_platform", "label": "Floored Casino Simulation Platform", "file_type": "document", "source_file": "AI_HANDSHAKE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_layout_stability", "label": "Layout Stability Convention", "file_type": "rationale", "source_file": "AI_HANDSHAKE.md", "source_location": "Non-obvious conventions \u00a7 Layout stability", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Board arena and control dock must never shift pixels between game phases (betting/playing/settled). Achieved via invisible+pointer-events-none instead of conditional mount, and fixed-height wrappers. Prevents janky UX from DOM reflow."}, {"id": "ai_handshake_engine_purity", "label": "Engine Purity Convention", "file_type": "rationale", "source_file": "AI_HANDSHAKE.md", "source_location": "Non-obvious conventions \u00a7 Engine purity", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "games/<name>/engine.ts must be pure functions with zero React imports and zero side effects. All randomness lives in the engine so components are purely presentational and engines are easily testable."}, {"id": "ai_handshake_tailwind_jit_data", "label": "Tailwind JIT Dynamic Class Warning", "file_type": "rationale", "source_file": "AI_HANDSHAKE.md", "source_location": "Non-obvious conventions \u00a7 Tailwind JIT + data objects", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tailwind JIT only scans .tsx/.ts at build time; dynamic class names from data arrays silently produce no styles. Colors from data must use inline style with hex strings."}, {"id": "ai_handshake_onresolve_contract", "label": "onResolve Bankroll Contract", "file_type": "rationale", "source_file": "AI_HANDSHAKE.md", "source_location": "Non-obvious conventions \u00a7 onResolve contract", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Page owns all bankroll math; game components never read/write bankroll store directly, only call onResolve({outcome, betAmount, payout, multiplier}). Keeps state ownership clear and prevents double-writes."}, {"id": "ai_handshake_game_registry", "label": "Game Registry (lib/game-registry.tsx)", "file_type": "code", "source_file": "AI_HANDSHAKE.md", "source_location": "Key files table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_survival_store", "label": "Survival Store (store/survival-store.ts)", "file_type": "code", "source_file": "AI_HANDSHAKE.md", "source_location": "Key files table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_freeplay_store", "label": "Freeplay Store (store/freeplay-store.ts)", "file_type": "code", "source_file": "AI_HANDSHAKE.md", "source_location": "Key files table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_settings_store", "label": "Settings Store (store/settings-store.ts)", "file_type": "code", "source_file": "AI_HANDSHAKE.md", "source_location": "Key files table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_balance_ts", "label": "Survival Balance Constants (lib/survival/balance.ts)", "file_type": "code", "source_file": "AI_HANDSHAKE.md", "source_location": "Key files table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_survival_perks_ts", "label": "Survival Perks Helpers (lib/survival/survival-perks.ts)", "file_type": "code", "source_file": "AI_HANDSHAKE.md", "source_location": "Key files table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_handshake_upgrades_catalog", "label": "Upgrades Catalog (lib/survival/upgrades-cat